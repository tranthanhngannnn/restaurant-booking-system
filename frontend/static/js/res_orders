async function payOrder() {
    if (!confirm("Xác nhận thanh toán cho bàn này?")) return;

    try {
        const res = await fetch(`http://127.0.0.1:5000/api/v1/restaurant/orders/pay/${tableId}`, {
            method: "PUT",
            headers: { "Content-Type": "application/json" }
        });

        if (res.ok) {
            alert("Thanh toán thành công! Bàn hiện đã trống.");
            window.location.href = "table.html";
        } else {
            const error = await res.json();
            alert("Lỗi: " + (error.error || "Thao tác thất bại"));
        }
    } catch (err) {
        console.error(err);
        alert("Lỗi kết nối server!");
    }
}

