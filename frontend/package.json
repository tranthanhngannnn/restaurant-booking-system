{
  "name": "golden-harvest-frontend-tests",
  "version": "1.0.0",
  "description": "Unit tests for Golden Harvest frontend",
  "type": "module",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "devDependencies": {
    "@babel/core": "^7.24.9",
    "@babel/preset-env": "^7.24.9",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "transform": {
      "^.+\\.(test|spec)\\.js$": "babel-jest",
      "^(?!.*node_modules).*\\.js$": "babel-jest"
    },
    "setupFilesAfterEnv": [
      "<rootDir>/setup-jest.js"
    ],
    "transformIgnorePatterns": [
      "/node_modules/"
    ]
  },
  "babel": {
    "presets": [
      "@babel/preset-env"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}